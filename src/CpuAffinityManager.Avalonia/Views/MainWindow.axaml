<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CpuAffinityManager.Avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="820"
        x:Class="CpuAffinityManager.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Title="{Binding WindowTitle}"
        Icon="/Assets/app.ico"
        MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="230,*">

        <!-- ═══ Sidebar ═══ -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                Background="{StaticResource SidebarBgBrush}">
            <Grid RowDefinitions="Auto,Auto,*">
                <!-- Logo -->
                <Border Grid.Row="0" Padding="16,14"
                        BorderBrush="{StaticResource SidebarHoverBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Image Source="avares://CpuAffinityManager.Avalonia/Assets/app-icon.png"
                               Width="22" Height="22"
                               Stretch="Uniform"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Loc.AppTitle}" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource TextOnDarkBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Nav -->
                <StackPanel Grid.Row="1" Margin="8,12,8,0" Spacing="2">
                    <Button Content="{DynamicResource Loc.Dashboard}"
                            Command="{Binding NavigateToDashboardCommand}"
                            Classes.nav-selected="{Binding IsDashboardSelected}"
                            Classes.nav="True"/>
                    <Button Content="{DynamicResource Loc.Processes}"
                            Command="{Binding NavigateToProcessesCommand}"
                            Classes.nav-selected="{Binding IsProcessesSelected}"
                            Classes.nav="True"/>
                    <Button Content="{DynamicResource Loc.Rules}"
                            Command="{Binding NavigateToRulesCommand}"
                            Classes.nav-selected="{Binding IsRulesSelected}"
                            Classes.nav="True"/>
                    <Button Content="{DynamicResource Loc.Settings}"
                            Command="{Binding NavigateToSettingsCommand}"
                            Classes.nav-selected="{Binding IsSettingsSelected}"
                            Classes.nav="True"/>
                </StackPanel>

                <!-- CPU Info Footer -->
                <Border Grid.Row="2" VerticalAlignment="Bottom"
                        Classes.sidebar-footer="True">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{DynamicResource Loc.CpuTopology}" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SidebarCpuInfo}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextOnDarkBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ Content Area ═══ -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
              RowDefinitions="Auto,*,Auto"
              Background="{StaticResource BgBrush}">

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                    Padding="20,12"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{DynamicResource Loc.AppTitle}" FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource Loc.AppSubtitle}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{DynamicResource Loc.ScanNow}"
                            Command="{Binding ScanNowCommand}"
                            IsEnabled="{Binding !IsScanning}"
                            Classes.primary="True"/>
                </Grid>
            </Border>

            <!-- Page Content (ViewModel-first via ViewLocator) -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}"
                            Margin="20"/>

            <!-- Status Bar -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                    Padding="16,6"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{StaticResource SuccessBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="v2.0.0" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
