<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CpuAffinityManager.Avalonia.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="CpuAffinityManager.Avalonia.Views.RuleListView"
             x:DataType="vm:RuleListViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource Loc.Rules}" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{DynamicResource Loc.RulesDescription}"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="{DynamicResource Loc.AddRule}" Classes.primary="True"
                    Command="{Binding AddRuleCommand}"/>
        </Grid>

        <!-- Rules List -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Rules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RuleItem">
                        <Border Classes.card="True" Padding="16" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <ToggleSwitch Grid.Column="0" IsChecked="{Binding Enabled}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Classes.tag="True">
                                            <TextBlock Text="{Binding Mode}" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Border>
                                        <Border CornerRadius="12" Padding="10,3" Background="{StaticResource PrimaryBgBrush}">
                                            <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                                        <Run Text="{DynamicResource Loc.Matches}"/><Run Text="{Binding ProcessPattern}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                                    <Button Content="✎" Classes.ghost="True"
                                            Command="{Binding $parent[UserControl].DataContext.EditRuleCommand}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Content="✕" Classes.danger="True"
                                            Command="{Binding $parent[UserControl].DataContext.DeleteRuleCommand}"
                                            CommandParameter="{Binding .}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <Border Grid.Row="1" IsVisible="{Binding !HasRules}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40">
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <TextBlock Text="📏" FontSize="36" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Loc.NoRules}" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{DynamicResource Loc.CreateFirstRule}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
