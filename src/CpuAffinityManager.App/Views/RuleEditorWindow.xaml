<Window x:Class="CpuAffinityManager.App.RuleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc.RuleEditor}" Width="520" Height="520"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="{StaticResource BgBrush}" CornerRadius="12">
    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Margin="1">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="DlgTitle" Text="{DynamicResource Loc.AddRule}" Style="{StaticResource Heading1}"/>
            <Button Content="✕" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" Click="Close_Click"/>
        </Grid>

        <!-- Fields -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Loc.RuleName}" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtName" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12" Text=""/>

            <TextBlock Text="{DynamicResource Loc.ProcessPattern}" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtProcess" Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>
            <TextBlock Text="{DynamicResource Loc.ProcessExample}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource Loc.PathPattern}" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
            <TextBox x:Name="TxtPath" Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>
            <TextBlock Text="{DynamicResource Loc.PathExample}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock Text="{DynamicResource Loc.AffinityMode}" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CmbMode" FontSize="13">
                        <ComboBoxItem Content="all-cores"/>
                        <ComboBoxItem Content="p-cores"/>
                        <ComboBoxItem Content="e-cores"/>
                        <ComboBoxItem Content="p-cores-smt"/>
                        <ComboBoxItem Content="p-cores-no-smt"/>
                        <ComboBoxItem Content="first-half"/>
                        <ComboBoxItem Content="second-half"/>
                        <ComboBoxItem Content="custom"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock Text="{DynamicResource Loc.EnforcementLevel}" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CmbLevel" FontSize="13">
                        <ComboBoxItem Content="soft-cpu-sets"/>
                        <ComboBoxItem Content="hard-affinity"/>
                        <ComboBoxItem Content="job-enforced"/>
                        <ComboBoxItem Content="job-locked"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                    <TextBlock Text="{DynamicResource Loc.CustomMask}" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtCustomMask" Style="{StaticResource ModernTextBox}" Text=""/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock Text="{DynamicResource Loc.SocketIndex}" Style="{StaticResource CaptionText}" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtSocket" Style="{StaticResource ModernTextBox}" Text="-1"/>
                </StackPanel>
            </Grid>

            <CheckBox x:Name="ChkLock" Content="{DynamicResource Loc.LockBreakaway}" Style="{StaticResource ModernCheckBox}" Margin="0,0,0,4"/>
            <CheckBox x:Name="ChkEnabled" Content="{DynamicResource Loc.Enabled}" Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="2">
            <Button Content="{DynamicResource Loc.Cancel}" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left" Click="Cancel_Click"/>
            <Button x:Name="BtnSave" Content="{DynamicResource Loc.SaveRule}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Click="Save_Click"/>
        </Grid>
    </Grid>
    </Border>
    </Border>
</Window>
